# Discord MCP Server - Configuration
# Fill in your tokens, then run start.bat (Windows) or start.sh (Mac/Linux).

# ===== Required =====
# Get your bot token from https://discord.com/developers
discord_bot_token = ""

# ===== Optional =====
# Restrict to a specific server (empty = respond in all servers)
# discord_guild_id = ""

# Restrict to a specific channel (empty = respond in all channels)
# discord_channel_id = ""

# Customize the AI's personality and rules
# bot_system_prompt = "You are a programming expert. Answer technical questions helpfully."

# Bot display name in prompts
# bot_name = ""

# Number of recent messages to include as context (default: 15)
# max_history = "15"

# Timeout in milliseconds (default: 120000 = 2 minutes)
# codex_timeout_ms = "120000"

# Path to codex.js entry point (auto-detected, usually not needed)
# codex_path = ""

# Working directory for Codex
# codex_workspace = ""
