# Discord MCP Server - 設定ファイル
# このファイルにトークンを書いたら、start.bat（Windows）またはstart.sh（Mac/Linux）をダブルクリックで起動できます。

# ===== 必須 =====
# Discord Developer Portal (https://discord.com/developers) で取得したBotトークン
discord_bot_token = ""

# OpenAI APIキー（https://platform.openai.com/api-keys で取得）
# リスナーモードでCodexが応答を生成するために必要です
openai_api_key = ""

# ===== オプション =====
# 特定のサーバーのみに制限（空欄 = 全サーバーで応答）
# discord_guild_id = ""

# 特定のチャンネルのみに制限（空欄 = 全チャンネルで応答）
# discord_channel_id = ""

# AIの性格やルールをカスタマイズ
# bot_system_prompt = "あなたはプログラミング専門のAIアシスタントです。"

# Bot表示名
# bot_name = ""

# 会話の記憶数（デフォルト: 15メッセージ）
# max_history = "15"

# タイムアウト秒数（デフォルト: 120秒）
# codex_timeout_ms = "120000"

# Codex CLIのパス（通常は自動検出するので不要）
# codex_path = ""

# Codexの作業ディレクトリ
# codex_workspace = ""

# オーナーのDiscord ID
# owner_id = ""
